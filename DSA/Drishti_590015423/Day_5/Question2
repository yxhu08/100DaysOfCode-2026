#include <stdio.h>
#include <stdbool.h>

// Function to swap two elements
void swap(int *a, int *b) {
    int temp = *a;
    *a = *b;
    *b = temp;
}

// Bubble sort function
void sort(int arr[], int n) {
    for (int i = 0; i < n - 1; i++) {
        for (int j = 0; j < n - i - 1; j++) {
            if (arr[j] > arr[j + 1]) {
                swap(&arr[j], &arr[j + 1]);
            }
        }
    }
}

// Function to check equality
bool areEqual(int arr1[], int arr2[], int n1, int n2) {
    if (n1 != n2)
        return false;

    sort(arr1, n1);
    sort(arr2, n2);

    for (int i = 0; i < n1; i++) {
        if (arr1[i] != arr2[i])
            return false;
    }

    return true;
}

int main() {
    int arr1[] = {1, 2, 3, 4};
    int arr2[] = {4, 3, 2, 1};

    int n1 = sizeof(arr1) / sizeof(arr1[0]);
    int n2 = sizeof(arr2) / sizeof(arr2[0]);

    if (areEqual(arr1, arr2, n1, n2))
        printf("True\n");
    else
        printf("False\n");

    return 0;
}
