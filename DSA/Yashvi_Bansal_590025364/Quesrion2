class Main {
    public static  String removeSpaces(String s)
    {
    StringBuilder ans= new StringBuilder();
    for(int i=0;i<s.length();i++)
    {
        if(s.charAt(i)!=' ')
        {
            ans.append(s.charAt(i));
        }
    }
    return ans.toString();
    
    
}
public static void main(String[] args)
{
    System.out.println(removeSpaces("C od  ing"));
}
}
